GATEKEEPER_BASE_URL=http://localhost:8001
GATEKEEPER_ADMIN_USER=admin
GATEKEEPER_ADMIN_PASSWORD=admin
LOGGING_LEVEL=DEBUG
WAIT_SECONDS_AFTER_UP=3
